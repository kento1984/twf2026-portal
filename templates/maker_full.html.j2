{% extends "_base.html.j2" %}

{% set brand = maker.brand or {} %}
{% set primary = brand.primary or '#C8102E' %}
{% set secondary = brand.secondary or '#8B0B20' %}
{% set accent = brand.accent or '#F5A623' %}
{% set text_on_primary = brand.text_on_primary or '#FFFFFF' %}

{% block extra_css %}
  /* === Full-bleed override (A-tier) === */
  body { background: var(--gray-50); }
  main.maker-page { max-width: none; padding: 0 0 96px; }
  .maker-content-wrap {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 32px;
  }

  /* === Hero banner (brand-colored full-bleed) === */
  .maker-hero {
    position: relative;
    color: {{ text_on_primary }};
    padding: 84px 32px 68px;
    overflow: hidden;
    background: linear-gradient(135deg, {{ primary }} 0%, {{ secondary }} 100%);
  }
  .maker-hero-pattern {
    position: absolute;
    top: -10%;
    right: -8%;
    width: 55%;
    height: 130%;
    background-image:
      radial-gradient(circle at 70% 50%, rgba(255,255,255,0.14) 0%, transparent 60%),
      repeating-linear-gradient(45deg, transparent 0 28px, rgba(255,255,255,0.045) 28px 30px);
    pointer-events: none;
    z-index: 1;
  }
  /* 汎用ロゴ表示 (maker.brand.logo_url があれば右上に大型配置) */
  .maker-hero-logo {
    position: absolute;
    top: 32px;
    right: 36px;
    z-index: 3;
    max-width: 320px;
    width: 30%;
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.35));
    pointer-events: none;
  }
  @media (max-width: 760px) {
    .maker-hero { padding-top: 260px; }
    .maker-hero-logo {
      top: 24px;
      right: 50%;
      transform: translateX(50%);
      max-width: 220px;
      width: 62%;
    }
  }
  .maker-hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .maker-hero-eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.8;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .maker-hero-no {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.1em;
    opacity: 0.7;
    padding: 4px 10px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 3px;
  }
  .maker-hero-tier {
    background: rgba(255,255,255,0.18);
    padding: 4px 12px;
    border-radius: 999px;
    font-weight: 800;
    letter-spacing: 0.06em;
  }
  .maker-hero-name {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 8px 0 14px;
  }
  .maker-hero-cat {
    margin: 0;
    font-size: 16px;
    opacity: 0.85;
    line-height: 1.55;
    max-width: 700px;
  }
  .maker-hero-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 22px 0 0;
  }
  .badge {
    display: inline-block;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  .badge-discount { background: #16a34a; color: #fff; }
  .badge-special { background: #9333ea; color: #fff; }
  .badge-priority { background: #dc2626; color: #fff; }
  .maker-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    padding: 11px 22px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: 999px;
    color: inherit !important;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none !important;
    transition: background 0.15s, transform 0.15s;
  }
  .maker-hero-cta:hover {
    background: rgba(255,255,255,0.28);
    transform: translateX(2px);
  }

  /* === Properties panel (Notion風 metadata) === */
  .maker-props {
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--gray-200);
    border-left: 6px solid {{ primary }};
    box-shadow: 0 12px 24px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.04);
    padding: 22px 32px;
    margin: -36px 0 48px;
    position: relative;
    z-index: 5;
  }
  .property-list { margin: 0; }
  .property-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 18px;
    padding: 14px 0;
    border-bottom: 1px solid var(--gray-100);
  }
  .property-row:last-child { border-bottom: none; }
  .property-row dt {
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-800);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .property-icon { font-size: 17px; line-height: 1.4; flex-shrink: 0; }
  .property-row dd {
    margin: 0;
    color: var(--gray-800);
    font-size: 15px;
    line-height: 1.7;
  }

  /* === Section heading === */
  .section-h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 24px;
    font-weight: 900;
    color: var(--gray-800);
    margin: 64px 0 24px;
    padding-bottom: 12px;
    border-bottom: 3px solid {{ primary }};
  }

  /* === Product info section (PDF extracted) === */
  .product-info { margin-top: 56px; }
  .product-section {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: 10px;
    padding: 24px 28px;
    margin-bottom: 20px;
    box-shadow: var(--shadow-md);
  }
  .product-section-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--gray-800);
    margin: 0 0 4px;
  }
  .product-section-subtitle {
    font-size: 13px;
    color: var(--gray-600);
    margin: 0 0 14px;
    line-height: 1.55;
  }
  .product-table-wrap {
    overflow-x: auto;
    margin: 8px 0 14px;
    border: 1px solid var(--gray-200);
    border-radius: 6px;
  }
  .product-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .product-table thead { background: var(--gray-100); }
  .product-table th {
    text-align: left;
    padding: 10px 14px;
    font-weight: 700;
    color: var(--gray-700);
    border-bottom: 2px solid var(--gray-200);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .product-table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--gray-100);
    color: var(--gray-800);
    vertical-align: top;
    line-height: 1.55;
  }
  .product-table tbody tr:last-child td { border-bottom: none; }
  .product-table tbody tr:hover { background: var(--gray-50); }
  .product-table .col-first {
    font-family: var(--font-mono);
    font-weight: 700;
    color: {{ primary }};
    white-space: nowrap;
  }
  .product-table .col-price {
    font-weight: 800;
    color: #C8102E;
    white-space: nowrap;
  }
  .product-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 12px;
    display: grid;
    gap: 6px;
  }
  .product-highlights li {
    padding: 9px 14px;
    background: var(--gray-50);
    border-left: 3px solid {{ accent }};
    font-size: 14px;
    color: var(--gray-800);
    border-radius: 0 4px 4px 0;
    line-height: 1.55;
  }
  .product-warning {
    margin-top: 12px;
    padding: 10px 14px;
    background: #fff8e1;
    border: 1px solid #f0c36d;
    border-radius: 6px;
    font-size: 13px;
    color: #7a5a1d;
    line-height: 1.6;
  }
  .new-models-line {
    margin-top: 8px;
    font-size: 13px;
    color: var(--gray-600);
  }
  .new-models-line .new-pill {
    display: inline-block;
    margin: 0 4px 4px 0;
    padding: 2px 8px;
    background: #16a34a;
    color: #fff;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  /* === Product gallery (graceful empty) === */
  .product-gallery { margin-top: 56px; }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }
  .product-card {
    margin: 0;
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }
  .product-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    background: var(--gray-50);
    padding: 12px;
  }
  .product-card figcaption {
    padding: 12px 16px;
    border-top: 1px solid var(--gray-100);
  }
  /* 画像未取得時のテキストオンリーカード: 高さを揃えてカード崩れ防止 */
  .product-card-textonly figcaption {
    border-top: none;
    padding: 20px 16px;
    min-height: 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .product-card-name {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-800);
    line-height: 1.4;
  }
  .product-card-cat {
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--gray-600);
  }
  /* === Product card clickable link wrapper === */
  .product-card-link {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }
  .product-card-link .product-card { transition: transform 0.18s ease, box-shadow 0.18s ease; }
  .product-card-link:hover .product-card {
    transform: translateY(-3px);
    box-shadow: 0 14px 28px rgba(0,0,0,0.14), 0 4px 8px rgba(0,0,0,0.06);
  }
  .product-card-link:hover .product-card-name { color: {{ primary }}; }
  .product-card-name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .product-card-arrow {
    font-size: 13px;
    color: var(--gray-500);
    opacity: 0.7;
    flex-shrink: 0;
    line-height: 1.4;
  }
  .product-card-link:hover .product-card-arrow {
    color: {{ primary }};
    opacity: 1;
  }

  /* === Q-list === */
  .q-list { display: flex; flex-direction: column; gap: 18px; }
  .q-card {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-left: 6px solid {{ primary }};
    border-radius: 10px;
    box-shadow: var(--shadow-md);
    padding: 24px 28px;
  }
  .q-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: {{ primary }};
    margin-bottom: 4px;
  }
  .q-title {
    font-size: 19px;
    font-weight: 800;
    color: var(--gray-800);
    margin: 0 0 12px;
  }
  .q-body {
    font-size: 16px;
    line-height: 1.85;
    color: var(--gray-800);
    white-space: pre-wrap;
  }
  .cross-maker-link {
    display: inline-block;
    color: #1a73e8;
    font-weight: bold;
    text-decoration: underline;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(26, 115, 232, 0.08);
    transition: background 0.15s;
  }
  .cross-maker-link:hover {
    background: rgba(26, 115, 232, 0.16);
  }
  .q5-only-notice {
    background: #fff8e1;
    border: 1px solid #f0c36d;
    border-left: 6px solid #e6a23c;
    border-radius: 8px;
    padding: 16px 20px;
    margin: 24px 0;
    font-size: 14px;
    line-height: 1.7;
    color: #7a5a1d;
  }
  .q5-only-notice strong { color: #6b4818; }

  /* === Attachments === */
  .attachments {
    margin-top: 24px;
    padding: 24px 28px;
    background: var(--gray-100);
    border-radius: 10px;
  }
  .pdf-card {
    margin-top: 18px;
    border: 1px solid var(--gray-200);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: #fff;
  }
  .pdf-card:first-of-type { margin-top: 0; }
  .pdf-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-200);
  }
  .pdf-card-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--gray-800);
    line-height: 1.45;
    word-break: break-all;
    flex: 1;
  }
  .pdf-download-btn {
    display: inline-block;
    padding: 8px 16px;
    background: {{ primary }};
    color: #fff !important;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none !important;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .pdf-download-btn:hover { opacity: 0.85; }
  .pdf-iframe {
    border: none;
    display: block;
    width: 100%;
    height: 700px;
    background: var(--gray-100);
  }
  .pdf-mobile-open {
    display: none;
    padding: 28px 20px;
    text-align: center;
    text-decoration: none !important;
    color: var(--gray-800);
    background: var(--gray-50);
    border-top: 1px solid var(--gray-200);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.5;
  }
  .pdf-mobile-open .pdf-mobile-icon {
    display: block;
    font-size: 40px;
    margin-bottom: 6px;
  }
  .pdf-mobile-open .pdf-mobile-hint {
    display: block;
    margin-top: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--gray-600);
    word-break: break-all;
  }
  @media (max-width: 760px) {
    .pdf-iframe { display: none; }
    .pdf-mobile-open { display: block; }
  }
  .video-player {
    display: block;
    width: 100%;
    max-height: 720px;
    background: #000;
    object-fit: contain;
  }
  .attach-path {
    margin-top: 16px;
    font-size: 12px;
    color: var(--gray-600);
  }
  .attach-path code {
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.04);
    padding: 2px 6px;
    border-radius: 3px;
    word-break: break-all;
  }

  /* === Pamphlet === */
  .pamphlet { margin-top: 0; }
  .pamphlet-meta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    font-size: 14px;
  }
  .pamphlet-section {
    display: inline-block;
    padding: 4px 12px;
    background: {{ primary }};
    color: #fff;
    border-radius: 999px;
    font-weight: 700;
    font-size: 13px;
  }
  .pamphlet-note-text {
    color: var(--gray-600);
    align-self: center;
    line-height: 1.5;
  }
  .pamphlet-img-wrap {
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: #fff;
  }
  .pamphlet-img-wrap img { width: 100%; height: auto; }
  .pamphlet-page-link {
    margin-top: 12px;
    text-align: right;
    font-size: 13px;
    color: var(--gray-600);
  }

  /* === Editorial note === */
  .editorial-note {
    margin-top: 56px;
    padding: 14px 18px;
    background: var(--gray-50);
    border: 1px dashed var(--gray-200);
    border-radius: 6px;
    font-size: 12px;
    line-height: 1.7;
    color: var(--gray-600);
  }
  .editorial-note .label {
    font-weight: 700;
    color: var(--gray-800);
    margin-right: 6px;
  }
  .editorial-note ul {
    margin: 6px 0 0 16px;
    padding: 0;
  }
  .editorial-note ul li {
    list-style: disc;
    margin-top: 2px;
    word-break: break-all;
  }
  .editorial-note a { color: var(--blue-500); }
{% endblock %}

{% block content %}
  <header class="maker-hero">
    <div class="maker-hero-pattern" aria-hidden="true"></div>
    {% if brand.logo_url %}
    <img class="maker-hero-logo" src="{{ brand.logo_url }}" alt="{{ brand.logo_alt or (maker.name ~ ' ロゴ') }}" loading="eager" />
    {% endif %}
    <div class="maker-hero-inner">
      <p class="maker-hero-eyebrow">
        <span class="maker-hero-no">No.{{ '%03d' | format(maker.no) }}</span>
        <span class="maker-hero-tier">A-Tier フル詳細</span>
        {% if maker.category %}<span>{{ maker.category }}</span>{% endif %}
      </p>
      <h1 class="maker-hero-name">{{ maker.name }}</h1>
      {% if not (maker.q3 | is_empty_q) %}<p class="maker-hero-cat">{{ maker.q3 | truncate(140, True, '…') }}</p>{% endif %}
      {% if maker.status_badges %}
      <div class="maker-hero-badges">
        {% for b in maker.status_badges %}
        <span class="badge badge-{{ b.type }}">{{ b.label }}</span>
        {% endfor %}
      </div>
      {% endif %}
      {% if brand.source %}
      {% set hero_src = brand.source[0] if (brand.source is iterable and brand.source is not string) else brand.source %}
      <a class="maker-hero-cta" href="{{ hero_src }}" target="_blank" rel="noopener">公式サイトを見る ↗</a>
      {% endif %}
    </div>
  </header>

  {# Phase 2-D: TWF みどころ特集 (該当topicに出展しているメーカーのみ表示) #}
  {% if twf_topic_products %}{% include '_twf_topic_section.html.j2' %}{% endif %}

  <div class="maker-content-wrap">

    {# サマリーセクション: ページ開いた瞬間の概要として 📌みどころ / 🎁セール企画 / 🆕新製品・新技術
       の3枠 (Q3/Q4/Q2 を 140字 truncate) を表示。📊製品テーブルは下部の抽出セクションへの
       予告として保持。📎配布資料の件数インデックスは「配布資料」表記の冗長性を避けるため非表示
       (添付セクション「📎 配布資料 (N件)」が下部にあり)。 #}
    <section class="maker-props">
      <dl class="property-list">
        {% if not (maker.q3 | is_empty_q) %}
        <div class="property-row">
          <dt><span class="property-icon">📌</span> みどころ</dt>
          <dd>{{ maker.q3 | truncate(140, True, '…') }}</dd>
        </div>
        {% endif %}
        {% if not (maker.q4 | is_empty_q) %}
        <div class="property-row">
          <dt><span class="property-icon">🎁</span> セール企画</dt>
          <dd>{{ maker.q4 | truncate(140, True, '…') }}</dd>
        </div>
        {% endif %}
        {% if not (maker.q2 | is_empty_q) %}
        <div class="property-row">
          <dt><span class="property-icon">🆕</span> 新製品・新技術</dt>
          <dd>{{ maker.q2 | truncate(140, True, '…') }}</dd>
        </div>
        {% endif %}
        {% if maker.pdf_extract and maker.pdf_extract.sections %}
        <div class="property-row">
          <dt><span class="property-icon">📊</span> 製品テーブル</dt>
          <dd>{{ maker.pdf_extract.sections | length }}カテゴリ抽出済み — モデル・特価・新製品をテーブル化</dd>
        </div>
        {% endif %}
      </dl>
    </section>

    {% if maker.pdf_extract and maker.pdf_extract.sections %}
    <h2 class="section-h2">📊 製品情報・特価リスト</h2>
    <section class="product-info">
      {% for section in maker.pdf_extract.sections %}
      <article class="product-section">
        <h3 class="product-section-title">{{ section.title }}</h3>
        {% if section.subtitle %}<p class="product-section-subtitle">{{ section.subtitle }}</p>{% endif %}
        {% if section.table_normalized and section.table_columns %}
        <div class="product-table-wrap">
          <table class="product-table">
            <thead>
              <tr>
                {% for c in section.table_columns %}<th>{{ c }}</th>{% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for cells in section.table_normalized %}
              <tr>
                {% for cell in cells %}
                  {% set col_name = section.table_columns[loop.index0] if loop.index0 < (section.table_columns | length) else '' %}
                  {% set is_first = loop.first %}
                  {% set is_price = '価格' in col_name or '特価' in col_name or '価' in col_name %}
                  <td class="{% if is_first %}col-first {% endif %}{% if is_price %}col-price{% endif %}">{{ cell }}</td>
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}
        {% if section.highlights %}
        <ul class="product-highlights">
          {% for h in section.highlights %}<li>🔹 {{ h }}</li>{% endfor %}
        </ul>
        {% endif %}
        {% if section.new_models %}
        <p class="new-models-line">🆕 新製品: {% for m in section.new_models %}<span class="new-pill">{{ m }}</span>{% endfor %}</p>
        {% endif %}
        {% if section.warnings %}
        <div class="product-warning">⚠️ {{ section.warnings | join(' / ') }}</div>
        {% endif %}
      </article>
      {% endfor %}
    </section>
    {% endif %}

    {% if maker.products and maker.products.fetched_ok and maker.products.products %}
    <h2 class="section-h2">🖼️ 主要製品 (公式サイト)</h2>
    <section class="product-gallery">
      <div class="product-grid">
        {% for p in maker.products.products %}
          {% if p.source_page %}
          <a href="{{ p.source_page }}" target="_blank" rel="noopener noreferrer" class="product-card-link" title="公式製品ページを新規タブで開く">
            <figure class="product-card{% if not p.image_url %} product-card-textonly{% endif %}">
              {% if p.image_url %}<img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy" />{% endif %}
              <figcaption>
                <div class="product-card-name-row">
                  <p class="product-card-name">{{ p.name }}</p>
                  <span class="product-card-arrow" aria-hidden="true">↗</span>
                </div>
                {% if p.category %}<p class="product-card-cat">{{ p.category }}</p>{% endif %}
              </figcaption>
            </figure>
          </a>
          {% else %}
          <figure class="product-card{% if not p.image_url %} product-card-textonly{% endif %}">
            {% if p.image_url %}<img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy" />{% endif %}
            <figcaption>
              <p class="product-card-name">{{ p.name }}</p>
              {% if p.category %}<p class="product-card-cat">{{ p.category }}</p>{% endif %}
            </figcaption>
          </figure>
          {% endif %}
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# Q1 は骨格として常に表示 (本文が truthy なら表示)。Q2〜Q4 は is_empty_q で沈黙判定。
       Q5 (配布資料・備考) は方針変更で全社一律非表示 — 添付セクションで情報伝達し、
       業務メール残骸/引用ノイズ/「添付あり N点」等の冗長表現を排除。 #}
    {% set q1_present = maker.q1 | trim if maker.q1 else false %}
    {% set q2_present = not (maker.q2 | is_empty_q) %}
    {% set q3_present = not (maker.q3 | is_empty_q) %}
    {% set q4_present = not (maker.q4 | is_empty_q) %}
    {% set q5_present = false %}
    {% set has_any_q = q1_present or q2_present or q3_present or q4_present %}

    {% if has_any_q %}
    <h2 class="section-h2">📝 メーカー回答 Q1〜Q4</h2>
    <section class="q-list">
      {% set qs = [
        ('Q1', '企画概要',         maker.q1, q1_present),
        ('Q2', '新製品・新技術',   maker.q2, q2_present),
        ('Q3', 'ブースのみどころ', maker.q3, q3_present),
        ('Q4', 'セール企画・特典', maker.q4, q4_present),
      ] %}
      {% for code, title, body, show in qs %}
        {% if show %}
        <article class="q-card">
          <div class="q-label">{{ code }} / {{ title }}</div>
          <h3 class="q-title">{{ title }}</h3>
          <div class="q-body">{{ body | autolink_maker }}</div>
        </article>
        {% endif %}
      {% endfor %}
    </section>
    {% endif %}

    {% if maker.attachments and maker.company_dir %}
    <h2 class="section-h2">📎 配布資料 ({{ maker.attachments | length }}件)</h2>
    <section class="attachments">
      {% for f in maker.attachments %}
        {% set href = "../../attachments/" ~ (maker.company_dir | urlquote) ~ "/" ~ (f | urlquote) %}
        {% set ext = f.rsplit('.', 1)[-1].lower() if '.' in f else '' %}
        {% set is_pdf = ext == 'pdf' %}
        {% set is_video = ext in ('mp4', 'webm', 'mov') %}
        {% set label = (maker.attachment_labels or {}).get(f) %}
      <div class="pdf-card">
        <div class="pdf-card-header">
          <h3>{% if is_video %}🎬{% else %}📄{% endif %} {% if label %}{{ label }} <small style="display:block;font-weight:500;font-size:12px;color:var(--gray-600);margin-top:2px;font-family:var(--font-mono);">{{ f }}</small>{% else %}{{ f }}{% endif %}</h3>
          <a href="{{ href }}" download class="pdf-download-btn">📥 ダウンロード</a>
        </div>
        {% if is_pdf %}
        <iframe src="{{ href }}" class="pdf-iframe" title="{{ f }} のプレビュー"></iframe>
        <a href="{{ href }}" class="pdf-mobile-open" target="_blank" rel="noopener">
          <span class="pdf-mobile-icon">📄</span>
          タップしてPDFを開く
          <span class="pdf-mobile-hint">{{ label or f }}</span>
        </a>
        {% elif is_video %}
        <video controls preload="metadata" class="video-player" title="{{ label or f }}">
          <source src="{{ href }}" type="video/{{ 'quicktime' if ext == 'mov' else ext }}">
          お使いのブラウザは動画再生に対応していません。
        </video>
        {% endif %}
      </div>
      {% endfor %}
      {% if maker.attachment_dir %}
      <p class="attach-path">保管先: <code>{{ maker.attachment_dir }}</code></p>
      {% endif %}
    </section>
    {% endif %}

    {# 外部公開資料: メーカー公式CDN等で公開済の大型カタログ等、Cloudflare Pages の
       25MB単一ファイル制限で portal 内に同梱できないリソースを外部URLで誘導 #}
    {% if maker.external_resources %}
    <h2 class="section-h2">🌐 公式公開資料 ({{ maker.external_resources | length }}件)</h2>
    <section class="external-resources">
      {% for r in maker.external_resources %}
      <div class="pdf-card">
        <div class="pdf-card-header">
          <h3>🌐 {{ r.label }}{% if r.note %} <small style="display:block;font-weight:500;font-size:12px;color:var(--gray-600);margin-top:2px;">{{ r.note }}</small>{% endif %}</h3>
          <a href="{{ r.url }}" target="_blank" rel="noopener noreferrer" class="pdf-download-btn">↗ 公式サイトで開く</a>
        </div>
      </div>
      {% endfor %}
      <p class="attach-path">提供: メーカー公式CDN (外部サイトへ遷移します)</p>
    </section>
    {% endif %}

    {% if maker.pamphlet_page %}
    <h2 class="section-h2">📕 公式パンフレットより</h2>
    <section class="pamphlet">
      {% if maker.pamphlet_section or maker.pamphlet_note %}
      <div class="pamphlet-meta">
        {% if maker.pamphlet_section %}<span class="pamphlet-section">{{ maker.pamphlet_section }}</span>{% endif %}
        {% if maker.pamphlet_note %}<span class="pamphlet-note-text">{{ maker.pamphlet_note }}</span>{% endif %}
      </div>
      {% endif %}
      <div class="pamphlet-img-wrap">
        <img src="../../data/pamphlet_pages/page_{{ '%03d' | format(maker.pamphlet_page) }}.png" alt="公式パンフレット p.{{ maker.pamphlet_page }}" />
      </div>
      <p class="pamphlet-page-link">公式パンフレット p.{{ maker.pamphlet_page }} に掲載</p>
    </section>
    {% endif %}

    {% if maker.is_rewritten %}
    <aside class="editorial-note">
      <span class="label">※</span>本ページの Q1〜Q4 は、メーカーからお預かりした回答と添付資料、メーカー公式サイト掲載情報を基に、主催店として読みやすく再編集しています。製品情報・特価リストは添付チラシ・カタログから抽出しました。
      {% if maker.web_sources %}
      <ul>
        {% for src in maker.web_sources %}<li><a href="{{ src }}" target="_blank" rel="noopener">{{ src }}</a></li>{% endfor %}
      </ul>
      {% endif %}
    </aside>
    {% endif %}

  </div>{# /.maker-content-wrap #}
{% endblock %}
