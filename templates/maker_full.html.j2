{% extends "_base.html.j2" %}

{% block extra_css %}
  .q-list { display: flex; flex-direction: column; gap: 24px; }
  .q-card {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-left: 6px solid var(--red-500);
    border-radius: 8px;
    box-shadow: var(--shadow-md);
    padding: 24px 28px;
  }
  .q-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--red-500);
    margin-bottom: 4px;
  }
  .q-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 12px;
  }
  .q-body {
    font-size: 16px;
    line-height: 1.85;
    color: var(--gray-800);
    white-space: pre-wrap;
  }

  .attachments {
    margin-top: 40px;
    padding: 24px 28px;
    background: var(--gray-100);
    border-radius: 8px;
  }
  .attachments h2 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--gray-800);
  }
  .attachments ul {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .attachments li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: 6px;
    font-size: 14px;
    color: var(--gray-800);
  }
  .attachments li::before {
    content: '📄';
    flex-shrink: 0;
  }
  .attach-path {
    margin-top: 12px;
    font-size: 12px;
    color: var(--gray-600);
  }
  .attach-path code {
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.04);
    padding: 2px 6px;
    border-radius: 3px;
    word-break: break-all;
  }

  .reply-meta {
    font-size: 13px;
    color: var(--gray-600);
    margin-top: 4px;
  }

  .q5-only-notice {
    background: #fff8e1;
    border: 1px solid #f0c36d;
    border-left: 6px solid #e6a23c;
    border-radius: 8px;
    padding: 16px 20px;
    margin-bottom: 20px;
    font-size: 14px;
    line-height: 1.7;
    color: #7a5a1d;
  }
  .q5-only-notice strong {
    color: #6b4818;
  }

  .pamphlet {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 2px solid var(--gray-200);
  }
  .pamphlet-h2 {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--gray-800);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .pamphlet-h2::before {
    content: '📕';
    font-size: 20px;
  }
  .pamphlet-meta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    font-size: 14px;
  }
  .pamphlet-section {
    display: inline-block;
    padding: 4px 12px;
    background: var(--blue-500);
    color: #fff;
    border-radius: 999px;
    font-weight: 700;
    font-size: 13px;
  }
  .pamphlet-note-text {
    color: var(--gray-600);
    align-self: center;
    line-height: 1.5;
  }
  .pamphlet-img-wrap {
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: #fff;
  }
  .pamphlet-img-wrap img {
    width: 100%;
    height: auto;
  }
  .pamphlet-page-link {
    margin-top: 12px;
    text-align: right;
    font-size: 13px;
    color: var(--gray-600);
  }
{% endblock %}

{% block content %}
  <header class="maker-header">
    <span class="tier-badge tier-a">フル詳細</span>
    <span class="maker-no">No.{{ '%03d' | format(maker.no) }}</span>
    <h1>{{ maker.name }}</h1>
    <div class="maker-meta">
      {% if maker.category %}<span>カテゴリ: {{ maker.category }}</span>{% endif %}
      {% if maker.reply_date %}<span>回答受信: {{ maker.reply_date }}</span>{% endif %}
    </div>
  </header>

  {% set q1_4_empty = not (maker.q1 or maker.q2 or maker.q3 or maker.q4) %}
  {% set q5_present = maker.q5 %}
  {% if q1_4_empty and q5_present %}
  <div class="q-5-only-wrap">
    <div class="q5-only-notice">
      <strong>⚠️ 個別企画情報は届いていません。</strong><br>
      Q1〜Q4 (企画概要 / 新製品 / みどころ / セール企画) の回答は本メーカーから提供されていないため、
      下記の<strong>配布資料・備考 (Q5) と添付ファイルのみ</strong>を掲載しています。
    </div>
  </div>
  {% endif %}

  <section class="q-list">
    {% set qs = [
      ('Q1', '企画概要', maker.q1),
      ('Q2', '新製品・新技術', maker.q2),
      ('Q3', 'ブースのみどころ', maker.q3),
      ('Q4', 'セール企画・特典', maker.q4),
      ('Q5', '配布資料・備考', maker.q5),
    ] %}
    {% for code, title, body in qs %}
      {% if body %}
      <article class="q-card">
        <div class="q-label">{{ code }} / {{ title }}</div>
        <h2 class="q-title">{{ title }}</h2>
        <div class="q-body">{{ body }}</div>
      </article>
      {% endif %}
    {% endfor %}
  </section>

  {% if maker.attachments %}
  <section class="attachments">
    <h2>添付資料 ({{ maker.attachments | length }}件)</h2>
    <ul>
      {% for f in maker.attachments %}<li>{{ f }}</li>{% endfor %}
    </ul>
    {% if maker.attachment_dir %}
    <p class="attach-path">保管先: <code>{{ maker.attachment_dir }}</code></p>
    {% endif %}
  </section>
  {% endif %}

  {% if maker.pamphlet_page %}
  <section class="pamphlet">
    <h2 class="pamphlet-h2">公式パンフレットより</h2>
    {% if maker.pamphlet_section or maker.pamphlet_note %}
    <div class="pamphlet-meta">
      {% if maker.pamphlet_section %}<span class="pamphlet-section">{{ maker.pamphlet_section }}</span>{% endif %}
      {% if maker.pamphlet_note %}<span class="pamphlet-note-text">{{ maker.pamphlet_note }}</span>{% endif %}
    </div>
    {% endif %}
    <div class="pamphlet-img-wrap">
      <img src="../../../data/pamphlet_pages/page_{{ '%03d' | format(maker.pamphlet_page) }}.png" alt="公式パンフレット p.{{ maker.pamphlet_page }}" />
    </div>
    <p class="pamphlet-page-link">公式パンフレット p.{{ maker.pamphlet_page }} に掲載</p>
  </section>
  {% endif %}
{% endblock %}
