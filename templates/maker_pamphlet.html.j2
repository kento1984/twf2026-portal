{% extends "_base.html.j2" %}

{% block extra_css %}
  .pamphlet-note {
    margin-bottom: 24px;
    padding: 16px 20px;
    background: rgba(0, 102, 204, 0.06);
    border-left: 4px solid var(--blue-500);
    border-radius: 4px;
    font-size: 14px;
    color: var(--gray-800);
  }
  .pamphlet-img-wrap {
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: #fff;
  }
  .pamphlet-img-wrap img {
    width: 100%;
    height: auto;
  }
  .pamphlet-meta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    font-size: 14px;
  }
  .pamphlet-section {
    display: inline-block;
    padding: 4px 12px;
    background: var(--blue-500);
    color: #fff;
    border-radius: 999px;
    font-weight: 700;
    font-size: 13px;
  }
  .pamphlet-note-text {
    color: var(--gray-600);
    align-self: center;
    line-height: 1.5;
  }
  .maker-header-cta {
    margin-top: 16px;
  }
  .maker-header-cta a {
    display: inline-block;
    padding: 10px 20px;
    background: var(--blue-500);
    color: #fff;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.2s;
  }
  .maker-header-cta a:hover {
    background: var(--blue-700);
  }
  /* Codex 18: 案 D modifier — CTA ある時だけ meta/CTA を同行化 */
  .maker-header--with-cta .maker-meta {
    width: auto;
    flex: 1 1 320px;
  }
  .maker-header--with-cta .maker-header-cta {
    margin-top: 0;
    margin-left: auto;
    align-self: center;
  }
  @media (max-width: 767px) {
    .maker-header--with-cta .maker-meta,
    .maker-header--with-cta .maker-header-cta {
      width: 100%;
      margin-left: 0;
    }
    .maker-header--with-cta .maker-header-cta {
      margin-top: 16px;
    }
  }
{% endblock %}

{% block content %}
  <header class="maker-header{% if twf_topic_products and twf_topic_products[0].official_url %} maker-header--with-cta{% endif %}">
    <span class="tier-badge tier-b">パンフ簡易</span>
    <span class="maker-no">No.{{ '%03d' | format(maker.no) }}</span>
    {% if maker.booth %}<span class="maker-booth">小間 {{ maker.booth }}</span>{% endif %}
    {% if maker.twf_first_exhibitor %}<span class="maker-first">★ 初TWF出展</span>{% endif %}
    <h1>{{ maker.name }}</h1>
    <div class="maker-meta">
      {% if maker.category %}<span>カテゴリ: {{ maker.category }}</span>{% endif %}
      <span>公式パンフレット p.{{ maker.pamphlet_page }}</span>
    </div>
    {% if twf_topic_products and twf_topic_products[0].official_url %}
    <div class="maker-header-cta">
      <a href="{{ twf_topic_products[0].official_url }}" target="_blank" rel="noopener">公式ページを見る ↗</a>
    </div>
    {% endif %}
  </header>

  {# Phase 2-D: TWF みどころ特集 (該当topicに出展しているメーカーのみ表示) #}
  {% if twf_topic_products %}{% include '_twf_topic_section.html.j2' %}{% endif %}

  {# Phase 2-D2 (5/18 拡張): Tier B でも rewritten 側に Q1-Q5 が入っていれば編集部再構成版を Q セクションで表示。
     rewritten が無い場合は従来通り「本社から回答未着」表示。Tier A (maker_full) / Tier C (maker_minimal) は不変更。 #}
  {% set q1_present = maker.q1 | trim if maker.q1 else false %}
  {% set q2_present = not (maker.q2 | is_empty_q) %}
  {% set q3_present = not (maker.q3 | is_empty_q) %}
  {% set q4_present = not (maker.q4 | is_empty_q) %}
  {% set q5_present = maker.q5 | trim if maker.q5 else false %}
  {% set has_any_q_rewritten = maker.is_rewritten and (q1_present or q2_present or q3_present or q4_present or q5_present) %}

  {% if has_any_q_rewritten %}
  <h2 class="section-h2">📝 メーカー回答 Q1〜Q5 <small style="font-weight:500;font-size:12px;color:var(--gray-600);margin-left:8px;">(本社からの個別回答未着のため、portal 編集部が公開資料から再構成)</small></h2>
  <section class="q-list">
    {% set qs = [
      ('Q1', '企画概要',         maker.q1, q1_present),
      ('Q2', '新製品・新技術',   maker.q2, q2_present),
      ('Q3', 'ブースのみどころ', maker.q3, q3_present),
      ('Q4', 'セール企画・特典', maker.q4, q4_present),
      ('Q5', '配布資料・備考',   maker.q5, q5_present),
    ] %}
    {% for code, title, body, show in qs %}
      {% if show %}
      <article class="q-card">
        <div class="q-label">{{ code }} / {{ title }}</div>
        <h3 class="q-title">{{ title }}</h3>
        <div class="q-body">{{ body | autolink_maker }}</div>
      </article>
      {% endif %}
    {% endfor %}
  </section>
  <p class="pamphlet-note">
    上記 Q1-Q5 は portal 編集部が公開資料 (PDF カタログ等) から再構成した参考情報です。本社からの正式回答が届き次第、フル詳細ページに自動で更新されます。以下は公式パンフレット該当ページです。
  </p>
  {% else %}
  <p class="pamphlet-note">
    本社からの個別回答はまだ届いていません。公式パンフレットの該当ページを以下に掲載しています。詳細回答が届き次第、フル詳細ページに自動で更新されます。
  </p>
  {% endif %}

  {% if maker.pamphlet_section or maker.pamphlet_note %}
  <div class="pamphlet-meta">
    {% if maker.pamphlet_section %}<span class="pamphlet-section">{{ maker.pamphlet_section }}</span>{% endif %}
    {% if maker.pamphlet_note %}<span class="pamphlet-note-text">{{ maker.pamphlet_note }}</span>{% endif %}
  </div>
  {% endif %}

  <div class="pamphlet-img-wrap">
    <img src="../../data/pamphlet_pages/page_{{ '%03d' | format(maker.pamphlet_page) }}.png" alt="公式パンフレット p.{{ maker.pamphlet_page }}" />
  </div>
{% endblock %}
