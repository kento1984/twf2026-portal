{% extends "_base.html.j2" %}

{% block title %}{{ topic.title }} | みどころ特集{% endblock %}

{% block extra_css %}
    /* ===== トピックページ (Phase 1.0 骨組み版) ===== */
    .topic-wrap {
      --accent: {{ topic.accent_color }};
      --accent-dark: {{ topic.accent_color_dark }};
    }
    .topic-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      gap: 40px;
      padding-bottom: 40px;
      margin-bottom: 48px;
      border-bottom: 2px solid var(--gray-200);
    }
    .topic-hero-text { align-self: center; }
    .topic-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 14px;
      background: var(--accent);
      color: #fff;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.10em;
      margin-bottom: 16px;
    }
    .topic-title {
      font-size: 36px;
      font-weight: 900;
      line-height: 1.22;
      letter-spacing: -0.01em;
      color: var(--gray-800);
      margin-bottom: 14px;
    }
    .topic-subtitle {
      font-size: 16px;
      font-weight: 600;
      color: var(--gray-600);
      margin-bottom: 18px;
      line-height: 1.55;
    }
    .topic-intro {
      font-size: 14.5px;
      line-height: 1.85;
      color: var(--gray-800);
      margin-bottom: 22px;
      max-width: 640px;
    }
    .topic-cta-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .btn-topic {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 22px;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 800;
      box-shadow: var(--shadow-md);
      transition: transform 150ms, box-shadow 150ms, background 150ms;
    }
    .btn-topic:hover {
      background: var(--accent-dark);
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
      text-decoration: none;
      color: #fff;
    }
    .btn-topic-outline {
      background: transparent;
      color: var(--accent);
      border: 2px solid var(--accent);
      box-shadow: none;
      padding: 9px 20px;
    }
    .btn-topic-outline:hover {
      background: var(--accent);
      color: #fff;
    }
    .topic-hero-flyer {
      align-self: start;
      max-height: 460px;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      background: var(--gray-100);
    }
    .topic-hero-flyer img {
      width: 100%;
      height: 100%;
      max-height: 460px;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    /* セクション */
    .topic-section { margin-bottom: 52px; }
    .topic-section-title {
      font-size: 22px;
      font-weight: 800;
      color: var(--gray-800);
      margin-bottom: 6px;
      display: inline-flex;
      align-items: center;
      gap: 12px;
    }
    .topic-section-title::before {
      content: '';
      display: inline-block;
      width: 4px;
      height: 24px;
      background: var(--accent);
      border-radius: 2px;
    }
    .topic-section-intro {
      font-size: 13.5px;
      color: var(--gray-600);
      margin-bottom: 22px;
      max-width: 720px;
      line-height: 1.7;
    }

    /* 製品カード */
    .topic-product-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .topic-product-card {
      position: relative;
      background: #fff;
      border: 1px solid var(--gray-200);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: var(--shadow-md);
      display: flex;
      flex-direction: column;
      transition: transform 200ms ease-out, box-shadow 200ms ease-out, border-color 200ms ease-out;
    }
    .topic-product-card:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
      box-shadow: 0 12px 28px rgba(0,0,0,0.10);
    }
    /* 画像あり: 16:9 サムネイル */
    .tpc-image {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: var(--gray-100);
      background-size: cover;
      background-position: center;
    }
    /* 画像なし: スリムなアクセントバー + メーカーNo装飾文字ヘッダ */
    .tpc-accent-bar {
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--accent) 0%, var(--accent-dark) 100%);
    }
    .tpc-decor-header {
      display: flex;
      align-items: baseline;
      gap: 14px;
      padding: 18px 22px 6px;
      border-bottom: 1px dashed var(--gray-200);
      margin-bottom: 12px;
    }
    .tpc-decor-no {
      font-family: var(--font-mono);
      font-size: 36px;
      font-weight: 900;
      line-height: 1;
      color: var(--accent);
      letter-spacing: -0.02em;
      flex-shrink: 0;
    }
    .tpc-decor-maker {
      font-size: 14px;
      font-weight: 800;
      color: var(--gray-800);
      line-height: 1.3;
      letter-spacing: 0.01em;
    }
    /* 画像なしカードでは tpc-body の上 padding を調整 (decor-header と二重 padding 防止) */
    .topic-product-card.no-image .tpc-body {
      padding-top: 0;
    }
    .topic-product-card.no-image .tpc-meta {
      display: none; /* decor-header が代替 */
    }
    .tpc-body {
      padding: 16px 20px 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex: 1;
    }
    .tpc-meta {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
    .tpc-meta-no {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--gray-400);
      letter-spacing: 0.06em;
      font-weight: 700;
    }
    .tpc-meta-name {
      font-size: 13px;
      color: var(--gray-600);
      font-weight: 700;
      letter-spacing: 0.02em;
    }
    .tpc-product {
      font-size: 16.5px;
      font-weight: 800;
      line-height: 1.4;
      color: var(--gray-800);
    }
    .tpc-tagline {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      line-height: 1.55;
    }
    .tpc-desc {
      font-size: 13px;
      color: var(--gray-600);
      line-height: 1.75;
    }
    .tpc-badges {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .tpc-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }
    .tpc-badge-first { background: #FEF3C7; color: #92400E; border: 1px solid #FCD34D; }
    .tpc-badge-new   { background: #DCFCE7; color: #14532D; border: 1px solid #86EFAC; }
    .tpc-links {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: auto;
      padding-top: 4px;
      font-size: 13px;
      font-weight: 700;
    }
    .tpc-links a {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .tpc-link-internal { color: var(--blue-500); }
    .tpc-link-external { color: var(--gray-600); }
    .tpc-link-external:hover { color: var(--accent); }
    .tpc-link-flyer {
      color: var(--accent);
      font-weight: 800;
    }
    .tpc-link-flyer:hover { color: var(--accent-dark); }

    /* TOPに戻るCTA */
    .topic-back-cta {
      margin-top: 8px;
      text-align: center;
    }
    .topic-back-cta a {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 11px 26px;
      background: var(--gray-800);
      color: #fff;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 700;
      box-shadow: var(--shadow-md);
    }
    .topic-back-cta a:hover { background: #000; text-decoration: none; color: #fff; }

    /* ===== Phase 2-B 拡張: ヒーロー動画 / 製品内動画 / 資料リンク / スライドギャラリー ===== */
    .topic-hero-video {
      max-width: var(--container-max);
      margin: -20px auto 56px;
      padding: 0 32px;
    }
    .topic-hero-video-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 800;
      color: var(--accent);
      letter-spacing: 0.04em;
      margin-bottom: 10px;
    }
    .topic-hero-video-label::before {
      content: '▶';
      display: inline-block;
    }
    .topic-hero-video-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 14px 32px rgba(0,0,0,0.12);
      background: #000;
    }
    .topic-hero-video-frame iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .topic-hero-video-caption {
      margin-top: 8px;
      font-size: 12.5px;
      color: var(--gray-600);
      font-weight: 600;
    }

    /* 製品カード: 動画埋め込み (single / multiple) */
    .tpc-videos {
      display: grid;
      gap: 12px;
      margin-top: 6px;
      grid-template-columns: 1fr;
    }
    .tpc-videos.multi {
      grid-template-columns: repeat(2, 1fr);
    }
    .tpc-video-embed {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      overflow: hidden;
      background: #000;
      box-shadow: var(--shadow-md);
    }
    .tpc-video-embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .tpc-video-caption {
      font-size: 11.5px;
      color: var(--gray-600);
      margin-top: 4px;
      font-weight: 600;
    }
    @media (max-width: 640px) {
      .tpc-videos.multi { grid-template-columns: 1fr; }
    }

    /* 製品カード: 配布資料リスト (複数 PDF対応) */
    .tpc-materials {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 6px;
      padding: 12px 14px;
      background: #FFF7ED;
      border-left: 3px solid var(--accent);
      border-radius: 6px;
    }
    .tpc-materials-label {
      font-size: 11px;
      font-weight: 800;
      color: var(--accent-dark);
      letter-spacing: 0.05em;
      margin-bottom: 2px;
    }
    .tpc-material {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 700;
      color: var(--accent);
    }
    .tpc-material:hover { color: var(--accent-dark); text-decoration: underline; }

    /* 製品カード: スライドギャラリー (画像 grid + lightbox-style) */
    .tpc-gallery {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px dashed var(--gray-200);
    }
    .tpc-gallery-title {
      font-size: 13.5px;
      font-weight: 800;
      color: var(--gray-800);
      margin-bottom: 4px;
    }
    .tpc-gallery-intro {
      font-size: 12px;
      color: var(--gray-600);
      margin-bottom: 12px;
      line-height: 1.6;
    }
    .tpc-gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 8px;
    }
    .tpc-gallery-item {
      display: block;
      position: relative;
      aspect-ratio: 16 / 9;
      background: var(--gray-100);
      border-radius: 5px;
      overflow: hidden;
      border: 1px solid var(--gray-200);
      transition: transform 200ms ease-out, box-shadow 200ms ease-out, border-color 200ms ease-out;
    }
    .tpc-gallery-item:hover {
      transform: translateY(-2px) scale(1.02);
      border-color: var(--accent);
      box-shadow: 0 6px 16px rgba(0,0,0,0.12);
    }
    .tpc-gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* 製品カード: 画像 (image_url) も画像onlyではない場合に表示 */
    /* (既存の .tpc-image を 16:9 にしているが、写真サムネ用に縮小可) */

    /* セクションタイトル装飾強化 (テーマ別セクション用) */
    .topic-section-title {
      font-size: 24px;
    }

    /* レスポンシブ: スマホ対応 */
    @media (max-width: 720px) {
      .topic-hero {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      .topic-title { font-size: 28px; }
      .topic-hero-video { padding: 0 16px; }
      .topic-product-grid {
        grid-template-columns: 1fr;
      }
      .tpc-gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
{% endblock %}

{% block content %}
<div class="topic-wrap">

  <!-- ヒーロー -->
  <section class="topic-hero">
    <div class="topic-hero-text">
      <span class="topic-eyebrow">{{ topic.icon }} みどころ3選 / TWF2026 メイン企画</span>
      <h1 class="topic-title">{{ topic.title }}</h1>
      <p class="topic-subtitle">{{ topic.subtitle }}</p>
      <p class="topic-intro">{{ topic.intro }}</p>
      <div class="topic-cta-row">
        {% if topic.pdf_url %}
        <a class="btn-topic" href="{{ topic.pdf_url }}" target="_blank" rel="noopener">📄 公式チラシをダウンロード</a>
        {% endif %}
        <a class="btn-topic btn-topic-outline" href="../../index.html#makerlist">出展メーカー一覧へ</a>
      </div>
    </div>
    {% if topic.hero_image %}
    <div class="topic-hero-flyer">
      <img src="{{ topic.hero_image }}" alt="{{ topic.title }} 公式チラシ" loading="lazy" />
    </div>
    {% endif %}
  </section>

  {# Phase 2-B: ヒーロー直下にメイン動画 (productivity-solutions用) #}
  {% if topic.hero_video %}
  <section class="topic-hero-video">
    <div class="topic-hero-video-label">会場前にまず予習: メインデモ動画</div>
    <div class="topic-hero-video-frame">
      <iframe src="https://www.youtube.com/embed/{{ topic.hero_video.youtube_id }}" title="{{ topic.hero_video.title }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
    </div>
    <div class="topic-hero-video-caption">{{ topic.hero_video.title }}{% if topic.hero_video.duration %} ({{ topic.hero_video.duration }}){% endif %}</div>
  </section>
  {% endif %}

  {# 単一products と sections (work-environmentのみ) どちらにも対応 #}
  {% set _blocks = topic.sections if topic.sections else [{"section_title": none, "section_intro": none, "products": topic.products}] %}
  {% for blk in _blocks %}
  <section class="topic-section">
    {% if blk.section_title %}
    <h2 class="topic-section-title">{{ blk.section_title }}</h2>
    {% if blk.section_intro %}<p class="topic-section-intro">{{ blk.section_intro }}</p>{% endif %}
    {% endif %}
    <div class="topic-product-grid">
      {% for p in blk.products %}
      <article class="topic-product-card{% if not p.image_url %} no-image{% endif %}">
        {% if p.image_url %}
        <div class="tpc-image" style="background-image: url('{{ p.image_url }}');"></div>
        {% else %}
        <div class="tpc-accent-bar"></div>
        <div class="tpc-decor-header">
          <span class="tpc-decor-no">{{ '%03d' | format(p.maker_no) }}</span>
          <span class="tpc-decor-maker">{{ p.maker_name }}</span>
        </div>
        {% endif %}
        <div class="tpc-body">
          <div class="tpc-meta">
            <span class="tpc-meta-no">No.{{ '%03d' | format(p.maker_no) }}</span>
            <span class="tpc-meta-name">{{ p.maker_name }}</span>
          </div>
          <div class="tpc-product">{{ p.product_name }}</div>
          {% if p.tagline %}<div class="tpc-tagline">{{ p.tagline }}</div>{% endif %}
          {% if p.description %}<div class="tpc-desc">{{ p.description }}</div>{% endif %}
          {% if p.is_first_exhibit or p.is_new_product %}
          <div class="tpc-badges">
            {% if p.is_first_exhibit %}<span class="tpc-badge tpc-badge-first">★ 初TWF出展</span>{% endif %}
            {% if p.is_new_product %}<span class="tpc-badge tpc-badge-new">🆕 新商品</span>{% endif %}
          </div>
          {% endif %}

          {# Phase 2-B: 製品カード内動画 (単数 video / 複数 videos どちらも対応) #}
          {% set _videos = [] %}
          {% if p.video %}{% set _videos = [p.video] %}{% endif %}
          {% if p.videos %}{% set _videos = p.videos %}{% endif %}
          {% if _videos %}
          <div class="tpc-videos{% if _videos|length > 1 %} multi{% endif %}">
            {% for v in _videos %}
            <div>
              <div class="tpc-video-embed">
                <iframe src="https://www.youtube.com/embed/{{ v.youtube_id }}" title="{{ v.title }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
              </div>
              <div class="tpc-video-caption">{{ v.title }}{% if v.duration %} ({{ v.duration }}){% endif %}</div>
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {# Phase 2-B: 配布資料リスト (複数 PDF 対応) #}
          {% if p.materials %}
          <div class="tpc-materials">
            <div class="tpc-materials-label">📚 メーカー配布資料</div>
            {% for m in p.materials %}
            <a class="tpc-material" href="{{ m.url }}" target="_blank" rel="noopener">{{ m.icon or '📄' }} {{ m.label }} ↗</a>
            {% endfor %}
          </div>
          {% endif %}

          <div class="tpc-links">
            {% if p.maker_slug %}
            <a class="tpc-link-internal" href="../../m/{{ p.maker_slug }}/">メーカー詳細 →</a>
            {% endif %}
            {% if p.flyer_url %}
            <a class="tpc-link-flyer" href="{{ p.flyer_url }}" target="_blank" rel="noopener">📄 {{ p.flyer_label or 'PDFチラシ' }} ↗</a>
            {% endif %}
            {% if p.official_url %}
            <a class="tpc-link-external" href="{{ p.official_url }}" target="_blank" rel="noopener">公式ページ ↗</a>
            {% endif %}
          </div>

          {# Phase 2-B: スライドギャラリー (Robotbank 14枚など) #}
          {% if p.slide_gallery %}
          <div class="tpc-gallery">
            <div class="tpc-gallery-title">{{ p.slide_gallery.title }}</div>
            {% if p.slide_gallery.intro %}<div class="tpc-gallery-intro">{{ p.slide_gallery.intro }}</div>{% endif %}
            <div class="tpc-gallery-grid">
              {% for img in p.slide_gallery.images %}
              <a class="tpc-gallery-item" href="{{ img.src }}" target="_blank" rel="noopener">
                <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy" />
              </a>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endfor %}

  <div class="topic-back-cta">
    <a href="../../index.html">← TOPページに戻る</a>
  </div>

</div>
{% endblock %}
