      {% set t = topics[slug] %}
      <a class="pickup-card" href="topics/{{ slug }}/"
         style="--card-accent: {{ t.accent_color }}; --card-accent-soft: color-mix(in srgb, {{ t.accent_color }} 45%, transparent);">
        <div class="pickup-card-title"><span class="pickup-card-icon">{{ t.icon }}</span>{{ t.card_title_short or t.title }}</div>
        <div class="pickup-card-count">{{ t.card_count_label }}</div>
        <div class="pickup-card-keywords">{{ t.card_keywords }}</div>
        <span class="pickup-card-cta">詳しく見る →</span>
