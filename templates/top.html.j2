  <!-- ============================================================
       Section 4: メーカー一覧  /  明  /  flex
       ============================================================ -->
  <section class="makerlist" id="makerlist">
    <div class="makerlist-inner">
      <div class="section-header">
        <h2 class="section-title double-underline double-underline-center">出展メーカー一覧</h2>
      </div>

      <div class="search-bar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input id="maker-search" type="text" placeholder="メーカー名・製品名・細分類で検索 (例: 照明, 測定器, カメラ)" autocomplete="off" />
      </div>

      <div class="filter-chips" role="list" aria-label="クイックフィルタ">
        <button type="button" class="filter-chip" data-nav-category="溶接・電源" data-filter="溶接|アーク|レーザー|スポット溶接|スタッド|電源"><span class="filter-chip-icon">🔥</span>溶接・電源</button>
        <button type="button" class="filter-chip" data-nav-category="切断・電動工具" data-filter="切断|グラインダ|セーバーソー|チップソー|ランス|サンダー"><span class="filter-chip-icon">🪚</span>切断・電動工具</button>
        <button type="button" class="filter-chip" data-nav-category="工具・消耗品" data-filter="ドリル|研磨|バリ取り|測定|工具|ケーブル|ライト|照明"><span class="filter-chip-icon">🔧</span>工具・消耗品</button>
        <button type="button" class="filter-chip" data-nav-category="保護具・安全" data-filter="保護|安全|防じん|墜落|ハーネス|ランヤード|遮光"><span class="filter-chip-icon">🛡️</span>保護具・安全</button>
        <button type="button" class="filter-chip" data-nav-category="ロボット・自動化" data-filter="ロボット|自動化|ロボメイト"><span class="filter-chip-icon">🤖</span>ロボット・自動化</button>
        <button type="button" class="filter-chip" data-nav-category="油圧・空圧" data-filter="油圧|空圧|エアー|コンプレッサ|減圧弁"><span class="filter-chip-icon">⚙️</span>油圧・空圧</button>
        <button type="button" class="filter-chip" data-nav-category="冷却・空調" data-filter="冷却|冷風|空調|スポットクーラー|暑熱|気化"><span class="filter-chip-icon">❄️</span>冷却・空調</button>
        <button type="button" class="filter-chip" data-nav-category="物流・運搬" data-filter="運搬|ハンドカー|ボンベ|スタンド|クレーン|クランプ|吊|スリング"><span class="filter-chip-icon">📦</span>物流・運搬</button>
      </div>
      <p class="filter-bridge-note">カード表記とフィルタ名は一部統合しています。例: 「安全機器」→「保護具・安全」、「照明・電気機器」→「工具・消耗品」</p>

      <p class="search-empty" id="search-empty" hidden>該当するメーカーが見つかりませんでした。検索ワードを変えて再度お試しください。</p>

      <div class="maker-tier-legend">
        <span class="tier-key tier-key-a"><span class="dot"></span>フル詳細 ({{ counts.A }}社)</span>
        <span class="tier-key tier-key-b"><span class="dot"></span>パンフ簡易 ({{ counts.B }}社)</span>
        <span class="tier-key tier-key-c"><span class="dot"></span>情報準備中 ({{ counts.C }}社)</span>
        <span class="tier-key tier-key-total">合計 {{ makers|length }}社</span>
      </div>

      {# Step D-3b (Codex 推奨 (C) 案、2026-05-16): A+B と C を別セクションに分離。
         macro 化で重複回避、検索 + 8 ボタンフィルタは両セクション横断のまま (JS 側で .maker-card 一括取得)。 #}
      {% macro render_maker_card(m) %}
        {% set _facets_str = (m.facets or []) | join(' ') %}
        {% set _search_blob = (m.name or '') ~ ' ' ~ (m.display_name or '') ~ ' ' ~ (m.name_short or '') ~ ' ' ~ (m.category or '') ~ ' No.' ~ ('%03d' | format(m.no)) ~ ' No' ~ ('%03d' | format(m.no)) ~ ' ' ~ (m.q1 or '') ~ ' ' ~ (m.q2 or '') ~ ' ' ~ (m.q3 or '') ~ ' ' ~ _facets_str %}
        <article class="maker-card maker-card-tier-{{ m.tier|lower }}"
                 data-tier="{{ m.tier }}"
                 data-search-text="{{ _search_blob }}"
                 data-nav-categories="{{ m.nav_categories or '' }}"
                 data-facets="{{ (m.facets or []) | join('|') }}"
                 {% if m.tier == 'A' and m.brand %}style="--brand-primary: {{ m.brand.primary }}; --brand-secondary: {{ m.brand.secondary }}; --brand-text: {{ m.brand.text_on_primary or '#FFFFFF' }};"{% endif %}>
          {% if m.tier == 'A' and m.is_recent %}<div class="maker-card-new"></div>{% endif %}
          {% if m.tier == 'A' or m.tier == 'B' %}
          <div class="maker-card-hero">
            <img class="maker-card-illust" src="assets/maker-illustrations/{{ '%03d' | format(m.no) }}.png" alt="{{ m.name }} 製品イメージ" loading="lazy" onerror="this.parentElement.classList.add('maker-card-hero-blank'); this.remove();" />
            {% if m.tier == 'A' and m.status_badges %}
            <div class="maker-card-badges">
              {% for b in m.status_badges %}<span class="mb-pill mb-{{ b.type }}">{{ b.label }}</span>{% endfor %}
            </div>
            {% endif %}
          </div>
          {% endif %}
          <div class="maker-card-body">
            <h3 class="maker-card-name">{{ m.name }}</h3>
            {% if m.name_short and m.name_short != m.name %}<div class="maker-card-name-sub">{{ m.name_short }}</div>{% endif %}
            <div class="maker-card-cat">No.{{ '%03d' | format(m.no) }}{% if m.card_category_display %} · {{ m.card_category_display }}{% endif %}{% if m.tier == 'B' and m.pamphlet_page %} · 公式パンフ p.{{ m.pamphlet_page }}{% endif %}</div>
            <a href="m/{{ m.slug }}/" class="maker-card-link is-link-block">{% if m.tier == 'A' %}詳細を見る{% elif m.tier == 'B' %}パンフを見る{% else %}情報準備中{% endif %}</a>
          </div>
        </article>
      {% endmacro %}

      {% if makers_main %}
      <section class="maker-section maker-section-main">
        <h3 class="maker-section-title">詳細掲載中 / パンフ掲載中 ({{ makers_main|length }}社)</h3>
        <div class="maker-grid">
          {% for m in makers_main %}{{ render_maker_card(m) }}{% endfor %}
        </div>
      </section>
      {% endif %}

      {% if makers_pending %}
      <section class="maker-section maker-section-pending">
        <h3 class="maker-section-title">情報準備中の出展メーカー ({{ makers_pending|length }}社)</h3>
        <p class="maker-section-intro">ブース出展はあります。詳細情報は順次公開予定です。</p>
        <div class="maker-grid">
          {% for m in makers_pending %}{{ render_maker_card(m) }}{% endfor %}
        </div>
      </section>
      {% endif %}
    </div>
  </section>

  <!-- ============================================================
       Section 5: 当日セール特価  /  明  /  16:9
       背景は top-route-pc.png (会場マップ) を装飾として継続使用
       ============================================================ -->
  <section class="sale">
    <div class="section-header">
      <h2 class="section-title double-underline double-underline-center">当日限定 セール特価</h2>
    </div>
    <div class="sale-content">
      <div class="sale-headline">
        <span class="accent">6/12-13</span> 当日限定の特別価格
      </div>
      <div class="sale-sub">
        <div class="sale-sub-item">
          <span class="sale-sub-icon">🎁</span>
          <span>30万円以上のお買い上げで成約記念品進呈</span>
        </div>
        <div class="sale-sub-item">
          <span class="sale-sub-icon">📺</span>
          <span>来場抽選会で大型液晶テレビが当たるチャンス</span>
        </div>
      </div>
      <div class="sale-cta-wrap">
        <a href="attachments/_common/2026WF_当日限定企画セールチラシ.pdf" target="_blank" rel="noopener" class="btn btn-blue">当日限定企画セールチラシを見る ▼</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 7: Footer  /  ガンメタ暗
       ============================================================ -->
  <footer class="footer">
    <div class="footer-inner">
      <div>
        <div class="footer-brand">マツモト産業株式会社 京葉営業所</div>
        <div class="footer-contact">
          <div><strong>TEL</strong>047-358-1121</div>
          <div><strong>FAX</strong>047-356-9022</div>
          <div><strong>住所</strong>〒272-0141 千葉県市川市香取2-12-20</div>
        </div>
      </div>
      <div class="footer-right">
        <a class="footer-link" href="https://mac-exe.co.jp/welding/welding_new/tokyo/" target="_blank" rel="noopener">
          TWF2026 公式サイトはこちら ↗
        </a>
        <div class="footer-meta">
          <div class="footer-meta-row">
            <span>本サイトは京葉営業所が主催店向けに公開しています</span>
          </div>
          <div class="footer-meta-row" id="updated-at"></div>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // フッター更新日時
    (function () {
      const updated = document.getElementById('updated-at');
      if (updated) {
        const d = new Date();
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        updated.innerHTML = '<span>更新日: ' + y + '-' + m + '-' + day + '</span>';
      }
    })();

    // ---- メーカー検索 + クイックフィルタチップ ----
    (function() {
      const input = document.getElementById('maker-search');
      if (!input) return;
      const cards = Array.from(document.querySelectorAll('.maker-card[data-search-text]'));
      const empty = document.getElementById('search-empty');
      const totalSpan = document.querySelector('.tier-key-total');
      const totalDefault = totalSpan ? totalSpan.textContent : '';
      const chips = Array.from(document.querySelectorAll('.filter-chip'));

      // 検索ボックス入力時の OR 部分一致 (旧ロジック維持、facets も検索対象)
      function applyQuery(raw) {
        const q = (raw || '').trim().toLowerCase();
        const parts = q.split('|').map(s => s.trim()).filter(Boolean);
        let visible = 0;
        cards.forEach(c => {
          const blob = (c.dataset.searchText || '').toLowerCase();
          const match = parts.length === 0 || parts.some(p => blob.indexOf(p) !== -1);
          c.hidden = !match;
          if (match) visible++;
        });
        if (empty) empty.hidden = !(q && visible === 0);
        if (totalSpan) {
          totalSpan.textContent = q ? ('絞り込み ' + visible + '/' + cards.length + '社') : totalDefault;
        }
      }

      // Step 7: 8 ボタン押下時の nav_categories 厳密一致モード
      // data-nav-categories="ロボット・自動化|溶接・電源" を split して category と厳密一致するか判定。
      // Codex policy 厳守: substring match ではなく == 一致のみ (偶発 recall を排除)。
      function applyNavCategoryFilter(category) {
        let visible = 0;
        cards.forEach(c => {
          const navs = (c.dataset.navCategories || '').split('|').map(s => s.trim()).filter(Boolean);
          const match = navs.includes(category);
          c.hidden = !match;
          if (match) visible++;
        });
        if (empty) empty.hidden = (visible !== 0);
        if (totalSpan) {
          totalSpan.textContent = '絞り込み ' + visible + '/' + cards.length + '社 (' + category + ')';
        }
      }

      input.addEventListener('input', () => {
        // ユーザーが手入力に切り替えたらチップの選択を解除
        chips.forEach(c => c.classList.remove('is-active'));
        applyQuery(input.value);
      });

      chips.forEach(chip => {
        chip.addEventListener('click', () => {
          const navCat = chip.dataset.navCategory || '';
          const wasActive = chip.classList.contains('is-active');
          chips.forEach(c => c.classList.remove('is-active'));
          if (wasActive) {
            input.value = '';
            applyQuery('');
          } else {
            chip.classList.add('is-active');
            input.value = '';
            if (navCat) {
              applyNavCategoryFilter(navCat);
            } else {
              // フォールバック: data-nav-category が無い場合は旧 keyword 検索
              const filter = chip.dataset.filter || '';
              input.value = filter;
              applyQuery(filter);
            }
          }
          // スクロール位置を絞り込み結果の頭に
          const grid = document.querySelector('.maker-grid');
          if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      if (input.value) applyQuery(input.value);
    })();

    // ---- TWF2026 開幕カウントダウン ----
    (function() {
      const start = new Date('2026-06-12T10:00:00+09:00').getTime();
      const end   = new Date('2026-06-13T18:00:00+09:00').getTime();
      const $d = document.getElementById('cd-days');
      const $h = document.getElementById('cd-hours');
      const $m = document.getElementById('cd-minutes');
      const $grid = document.getElementById('countdown-grid');
      const $title = document.getElementById('countdown-title');
      const $status = document.getElementById('countdown-status');
      if (!$d || !$h || !$m || !$grid || !$title || !$status) return;

      function pad(n) { return String(n).padStart(2, '0'); }

      function tick() {
        const now = Date.now();
        if (now < start) {
          const diff = start - now;
          const days = Math.floor(diff / 86400000);
          const hours = Math.floor((diff % 86400000) / 3600000);
          const minutes = Math.floor((diff % 3600000) / 60000);
          $d.textContent = days;
          $h.textContent = pad(hours);
          $m.textContent = pad(minutes);
        } else if (now < end) {
          $title.textContent = '🎉 TWF2026 開催中';
          $grid.hidden = true;
          $status.hidden = false;
          $status.textContent = '幕張メッセ No.9 ホールでお待ちしております';
        } else {
          $title.textContent = 'ご来場ありがとうございました';
          $grid.hidden = true;
          $status.hidden = false;
          $status.textContent = '次回 TWF でまたお会いしましょう';
        }
      }

      tick();
      setInterval(tick, 60000);  // 1分おき更新
    })();
  </script>
</body>
</html>
