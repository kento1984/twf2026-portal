  <!-- ============================================================
       Section 3: みどころ3選 (TWF2026 メイン企画)
       ステージ (3スポット背景) + 直下カード接続 + accent_color差別化
       data/topics.json を build_html.py から渡された topics でループ生成
       ============================================================ -->
  <section class="pickup-section">
    <div class="pickup-stage">
      <div class="section-header">
        <span class="pickup-eyebrow">みどころ3選 / TWF2026 メイン企画</span>
        <h2 class="section-title section-title-light double-underline double-underline-center">2大コーナー × 実演セミナー</h2>
