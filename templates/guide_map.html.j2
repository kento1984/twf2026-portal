{% extends "_base.html.j2" %}
{% block title %}公式ガイドマップ{% endblock %}

{% block extra_css %}
  .gm-hero {
    background: linear-gradient(135deg, #1e293b 0%, #1e40af 100%);
    color: #fff;
    padding: 56px 32px 48px;
    margin-bottom: 40px;
    text-align: center;
  }
  .gm-hero-inner { max-width: 1100px; margin: 0 auto; }
  .gm-hero-eyebrow {
    display: inline-block;
    padding: 5px 14px;
    background: rgba(255,255,255,0.18);
    color: #fff;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.10em;
    margin-bottom: 14px;
  }
  .gm-hero h1 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    line-height: 1.2;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .gm-hero-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    max-width: 760px;
    margin: 0 auto 22px;
    line-height: 1.75;
  }
  .gm-hero-cta-row {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
  }
  .gm-cta-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    background: #fff;
    color: #1e40af;
    border-radius: 6px;
    font-size: 14px; font-weight: 800; text-decoration: none;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
  .gm-cta-btn:hover { background: #fef3c7; text-decoration: none; }
  .gm-cta-btn-outline {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.55);
    box-shadow: none;
  }
  .gm-cta-btn-outline:hover { background: rgba(255,255,255,0.12); color: #fff; text-decoration: none; }

  .gm-section { max-width: 1100px; margin: 0 auto 56px; padding: 0 32px; }
  .gm-section-head {
    border-bottom: 3px solid #1e40af;
    padding-bottom: 8px;
    margin-bottom: 22px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 8px;
  }
  .gm-section h2 {
    font-size: 22px;
    font-weight: 900;
    color: #1e293b;
    margin: 0;
  }
  .gm-section-note {
    font-size: 12px;
    color: #64748b;
  }
  .gm-section-intro {
    font-size: 14px;
    color: #475569;
    line-height: 1.75;
    margin: 0 0 18px;
  }

  /* === 会場マップ === */
  .gm-venue-map-wrap {
    text-align: center;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
  }
  .gm-venue-map {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: 6px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.10);
  }
  .gm-venue-map-cta {
    margin-top: 12px;
    font-size: 13px;
    font-weight: 700;
    color: #1e40af;
  }

  /* === 実演デモ === */
  .gm-demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 18px;
  }
  .gm-demo-card {
    --demo-accent: #BE123C;
    background: #fff;
    border: 1px solid var(--demo-accent);
    border-top: 4px solid var(--demo-accent);
    border-radius: 10px;
    padding: 18px 20px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  }
  .gm-demo-head {
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: 8px; margin-bottom: 6px;
  }
  .gm-demo-maker { font-size: 17px; font-weight: 900; color: var(--demo-accent); }
  .gm-demo-booth {
    font-family: var(--font-mono);
    font-size: 12px; font-weight: 800;
    color: #b45309; background: #fef3c7; border: 1px solid #fde68a;
    padding: 2px 8px; border-radius: 3px;
    letter-spacing: 0.04em;
  }
  .gm-demo-title { font-size: 14px; font-weight: 800; color: #2C2C2C; line-height: 1.4; }
  .gm-demo-subtitle {
    font-size: 12px; color: #52525B; font-weight: 600;
    margin: 2px 0 12px; line-height: 1.55;
  }
  .gm-demo-days {
    display: flex; flex-direction: column; gap: 6px;
    padding-top: 10px; border-top: 1px dashed #E4E4E7;
  }
  .gm-demo-day { display: flex; gap: 14px; align-items: baseline; }
  .gm-demo-day-label {
    font-size: 13px; font-weight: 800; color: var(--demo-accent);
    min-width: 64px; font-family: var(--font-mono);
  }
  .gm-demo-times {
    font-family: var(--font-mono); font-size: 15px;
    font-weight: 700; color: #2C2C2C; letter-spacing: 0.04em;
  }
  .gm-demo-free {
    display: inline-block;
    font-size: 11px; font-weight: 800; color: #15803d;
    background: #dcfce7; border: 1px solid #86efac;
    padding: 2px 8px; border-radius: 3px;
    letter-spacing: 0.04em;
    margin-top: 8px;
  }

  /* === 主催店テーブル === */
  .gm-table {
    width: 100%; border-collapse: collapse; font-size: 13.5px;
  }
  .gm-table th, .gm-table td {
    padding: 9px 12px;
    border-bottom: 1px solid #e2e8f0;
    text-align: left;
  }
  .gm-table thead th {
    background: #1e40af; color: #fff;
    font-weight: 800; font-size: 12px;
    letter-spacing: 0.05em;
  }
  .gm-table tbody tr:hover { background: #f8fafc; }
  .gm-table .col-booth {
    width: 110px;
    font-family: var(--font-mono);
    font-weight: 800;
    color: #b45309;
    background: #fffbeb;
    text-align: center;
  }
  .gm-table .col-name { font-weight: 700; color: #1e293b; }
  .gm-table .col-furigana { font-size: 11.5px; color: #64748b; }
  .gm-table a.gm-link { color: #1e40af; font-weight: 700; text-decoration: none; }
  .gm-table a.gm-link:hover { text-decoration: underline; }
  .gm-table .row-overlap td:first-child::before {
    content: '★ ';
    color: #d97706;
  }
  .gm-overlap-note {
    font-size: 12px; color: #92400e; background: #fef3c7;
    border: 1px solid #fde68a; border-radius: 6px;
    padding: 10px 14px; margin-bottom: 12px;
  }

  /* === PDF 全体 === */
  .gm-pdf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .gm-pdf-card {
    display: block; text-decoration: none; color: inherit;
    background: #fff; border: 1px solid #e2e8f0;
    border-radius: 10px; overflow: hidden;
    transition: transform 200ms, box-shadow 200ms, border-color 200ms;
  }
  .gm-pdf-card:hover {
    transform: translateY(-2px); border-color: #1e40af;
    box-shadow: 0 10px 24px rgba(30,64,175,0.14);
    text-decoration: none;
  }
  .gm-pdf-card img {
    width: 100%; height: auto; display: block;
    border-bottom: 1px solid #e2e8f0;
  }
  .gm-pdf-card-body { padding: 14px 18px; }
  .gm-pdf-card-title { font-size: 14px; font-weight: 800; color: #1e293b; }
  .gm-pdf-card-desc { font-size: 12px; color: #64748b; margin-top: 3px; }

  .gm-back {
    text-align: center; margin: 48px 0 24px;
  }
  .gm-back a {
    display: inline-block; padding: 11px 22px;
    background: #1e40af; color: #fff; border-radius: 6px;
    font-size: 14px; font-weight: 800; text-decoration: none;
  }
  .gm-back a:hover { background: #1e3a8a; text-decoration: none; }

  @media (max-width: 720px) {
    .gm-hero { padding: 36px 20px 32px; }
    .gm-section { padding: 0 18px; margin-bottom: 36px; }
    .gm-demo-grid { grid-template-columns: 1fr; }
    .gm-pdf-grid { grid-template-columns: 1fr; }
    .gm-table { font-size: 12px; }
    .gm-table th, .gm-table td { padding: 7px 8px; }
  }
{% endblock %}

{% block content %}
<header class="gm-hero">
  <div class="gm-hero-inner">
    <span class="gm-hero-eyebrow">🗺️ OFFICIAL GUIDEMAP</span>
    <h1>公式ガイドマップ</h1>
    <p class="gm-hero-sub">
      主催店配布版の公式ガイドマップ (両面A3) を 1 ページに集約。会場の全体像、実演デモ時間、
      主催店33社、共同小間出展者を来場前に確認できます。
    </p>
    <div class="gm-hero-cta-row">
      <a class="gm-cta-btn" href="../assets/pdf/26TWF_official_guidemap.pdf" target="_blank" rel="noopener">📥 PDF をダウンロード (A3 両面)</a>
      <a class="gm-cta-btn gm-cta-btn-outline" href="../index.html">← TOP に戻る</a>
    </div>
  </div>
</header>

<!-- 1. 会場マップ -->
<section class="gm-section" id="venue-map">
  <div class="gm-section-head">
    <h2>1. 会場マップ</h2>
    <span class="gm-section-note">A〜I ブロック、主催店、コーナー、入口/出口の配置図</span>
  </div>
  <a class="gm-venue-map-wrap" href="../assets/maps/guidemap_front.png" target="_blank" rel="noopener" style="text-decoration: none; display: block;">
    <img class="gm-venue-map" src="../assets/maps/venue_map.webp" alt="TWF2026 会場マップ (出展メーカーの小間配置)" loading="lazy" />
    <div class="gm-venue-map-cta">クリックで原寸表示 / PDF 表面全体を見る →</div>
  </a>
</section>

<!-- 2. 実演デモ時間表 -->
{% if demo_schedule %}
<section class="gm-section" id="demo">
  <div class="gm-section-head">
    <h2>2. 実演デモ時間表</h2>
    <span class="gm-section-note">参加無料・予約不要</span>
  </div>
  <p class="gm-section-intro">3M フルハーネスデモと神戸製鋼 AXELARC デモは、両日複数回開催。会場では指定時刻にブースで開始します。</p>
  <div class="gm-demo-grid">
    {% for no, d in demo_schedule.items() %}
    <div class="gm-demo-card" style="--demo-accent: {% if no == '058' %}#1e40af{% else %}#BE123C{% endif %};">
      <div class="gm-demo-head">
        <div class="gm-demo-maker">{{ d.maker_name }}</div>
        {% if d.booth %}<span class="gm-demo-booth">小間 {{ d.booth }}</span>{% endif %}
      </div>
      <div class="gm-demo-title">{{ d.demo_title }}</div>
      {% if d.demo_subtitle %}<div class="gm-demo-subtitle">{{ d.demo_subtitle }}</div>{% endif %}
      <div class="gm-demo-days">
        {% for day in d.schedule %}
        <div class="gm-demo-day">
          <span class="gm-demo-day-label">{{ day.label }}</span>
          <span class="gm-demo-times">{{ day.times | join(' / ') }}</span>
        </div>
        {% endfor %}
      </div>
      {% if d.participation %}<div class="gm-demo-free">{{ d.participation }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- 3. 主催店 33社 + 共同小間 -->
<section class="gm-section" id="sponsors">
  <div class="gm-section-head">
    <h2>3. 主催店・共同小間出展者 ({{ guide_only|length + overlap|length }}社)</h2>
    <span class="gm-section-note">小間番号順</span>
  </div>
  {% if overlap %}
  <div class="gm-overlap-note">
    ★ マーク付き ({{ overlap|length }}社) は出展メーカー一覧 (149社) にも登録あり、メーカー側の booth + 主催店 booth を併記済み。
  </div>
  {% endif %}
  <table class="gm-table">
    <thead>
      <tr>
        <th class="col-booth">小間</th>
        <th>会社名 / 読み</th>
        <th>備考</th>
      </tr>
    </thead>
    <tbody>
      {% for s in sponsors_sorted %}
      <tr{% if s.overlap_no %} class="row-overlap"{% endif %}>
        <td class="col-booth">{{ s.booth }}</td>
        <td>
          <span class="col-name">{{ s.name }}</span>
          {% if s.furigana %}<span class="col-furigana"> ({{ s.furigana }})</span>{% endif %}
        </td>
        <td>
          {% if s.overlap_no %}
          <a class="gm-link" href="../m/{{ s.overlap_slug }}/">メーカー詳細 (No.{{ '%03d' | format(s.overlap_no) }}) →</a>
          {% elif s.joint_note %}
          {{ s.joint_note }}
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>

<!-- 4. PDF 全体 -->
<section class="gm-section" id="pdf">
  <div class="gm-section-head">
    <h2>4. PDF 全ページ</h2>
    <span class="gm-section-note">クリックで PDF を開く</span>
  </div>
  <div class="gm-pdf-grid">
    <a class="gm-pdf-card" href="../assets/pdf/26TWF_official_guidemap.pdf" target="_blank" rel="noopener">
      <img src="../assets/maps/guidemap_front.webp" alt="ガイドマップ表面" loading="lazy" />
      <div class="gm-pdf-card-body">
        <div class="gm-pdf-card-title">表面 — 会場マップ + メーカー一覧</div>
        <div class="gm-pdf-card-desc">A〜I ブロックの全小間、主催店33社、抽選コーナー、入口/出口</div>
      </div>
    </a>
    <a class="gm-pdf-card" href="../assets/pdf/26TWF_official_guidemap.pdf" target="_blank" rel="noopener">
      <img src="../assets/maps/guidemap_back.webp" alt="ガイドマップ裏面" loading="lazy" />
      <div class="gm-pdf-card-body">
        <div class="gm-pdf-card-title">裏面 — 注目商品ショーケース</div>
        <div class="gm-pdf-card-desc">いちおしメーカー5社、生産性向上・作業環境向上コーナー、実演デモ</div>
      </div>
    </a>
  </div>
</section>

<div class="gm-back">
  <a href="../index.html">← TOP ページに戻る</a>
</div>
{% endblock %}
